# Discord bot token from Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# PostgreSQL DSN (example)
# postgresql://username:password@localhost:5432/hoi4_bot
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hoi4_bot

# Optional (default is !)
COMMAND_PREFIX=!

# Optional: for instant slash command updates during development
# (instead of waiting for global command propagation)
DEV_GUILD_ID=
